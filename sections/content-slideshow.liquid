<script src="{{ 'content-slideshow.js' | asset_url }}" type="module"></script>

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<content-slideshow
  class="cs section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  data-autoplay="{{ section.settings.autoplay_speed }}"
  style="
    {% render 'spacing-style', settings: section.settings %}
    --cs-image-ratio: {{ section.settings.image_ratio }};
  "
>

  {%- comment -%} Slides {%- endcomment -%}
  <div class="cs__track">
    {%- for block in section.blocks -%}
      <div
        class="cs__slide"
        data-slide="{{ forloop.index0 }}"
        aria-hidden="true"
        {{ block.shopify_attributes }}
      >
      
        <div class="cs__slide-inner">
        {%- comment -%} Image + label {%- endcomment -%}
        <div class="cs__image-wrap">
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 1200
              | image_tag:
                class: 'cs__image',
                loading: 'lazy',
                widths: '600, 900, 1200',
                alt: block.settings.heading | escape
            }}
          {%- else -%}
            <div class="cs__image-placeholder">
              {{ 'image' | placeholder_svg_tag: 'cs__placeholder-svg' }}
            </div>
          {%- endif -%}

          {%- if block.settings.label != blank -%}
            <span class="cs__label">{{ block.settings.label | escape }}</span>
          {%- endif -%}
        </div>

        {%- comment -%} Text content {%- endcomment -%}
        <div class="cs__content">
          {%- if block.settings.heading != blank -%}
            <h2 class="cs__heading">{{ block.settings.heading | escape }}</h2>
          {%- endif -%}

          {%- if block.settings.text != blank -%}
            <p class="cs__text">{{ block.settings.text | escape }}</p>
          {%- endif -%}

          {%- if block.settings.link_label != blank -%}
            <a
              href="{{ block.settings.link | default: '#' }}"
              class="cs__link"
            >
              {{ block.settings.link_label | escape }}
            </a>
          {%- endif -%}
        </div>
        </div>{%- comment -%} /cs__slide-inner {%- endcomment -%}
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    {%- comment -%} Dot pagination — mobile only {%- endcomment -%}
    <div class="cs__dots" role="tablist" aria-label="Slideshow navigation">
      {%- for block in section.blocks -%}
        <button
          class="cs__dot{% if forloop.first %} is-active{% endif %}"
          data-dot="{{ forloop.index0 }}"
          role="tab"
          aria-label="Slide {{ forloop.index }}"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
        ></button>
      {%- endfor -%}
    </div>

    {%- comment -%} Prev/Next buttons — desktop only {%- endcomment -%}
    <div class="cs__controls">
      <button type="button" class="cs__control-btn" data-action="previous" aria-label="Previous slide">
        {{- 'icon-arrow.svg' | inline_asset_content -}}
        <span>Back</span>
      </button>
      <button type="button" class="cs__control-btn" data-action="next" aria-label="Next slide">
        <span>Next</span>
        {{- 'icon-arrow.svg' | inline_asset_content -}}
      </button>
    </div>
  {%- endif -%}

</content-slideshow>

{% stylesheet %}
  content-slideshow {
    display: block;
    width: 100%;
  }

  /* --- Track: CSS grid stacking so height follows active slide --- */
  .cs__track {
    display: grid;
    width: 100%;
  }

  .cs__slide {
    grid-area: 1 / 1;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .cs__slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  /* --- Slide inner layout: stacked mobile, side-by-side desktop --- */
  .cs__slide-inner {
    display: flex;
    flex-direction: column;
  }

  @media screen and (min-width: 750px) {
    .cs__slide-inner {
      flex-direction: row;
      align-items: stretch;
    }
  }

  /* --- Image --- */
  .cs__image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: var(--cs-image-ratio, 4 / 3);
    overflow: hidden;
    background: #111;
    flex-shrink: 0;
  }

  @media screen and (min-width: 750px) {
    .cs__image-wrap {
      width: 50%;
    }
  }

  .cs__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cs__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
  }

  .cs__placeholder-svg {
    width: 100%;
    height: 100%;
  }

  /* --- Label overlay (top-left of image) --- */
  .cs__label {
    position: absolute;
    top: 1rem;
    left: 1rem;
    font-family: inherit;
    font-size: var(--font-size-sm, 0.75rem);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #ffffff;
    background: rgba(187, 187, 187, 0.25);
    border: 1px solid #f9f9f9;
    padding: var(--padding-sm, 0.35rem) var(--padding-md, 0.65rem);
    line-height: 1;
    white-space: nowrap;
  }

  /* --- Content beside/below image --- */
  .cs__content {
    padding: 1.5rem var(--page-margin, 1.5rem) 0.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.75rem;
  }

  @media screen and (min-width: 750px) {
    .cs__content {
      width: 50%;
      padding: 2.5rem 3rem;
    }
  }

  .cs__heading {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    line-height: 1.05;
    margin: 0;
    color: var(--color-foreground);
  }

  .cs__text {
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
    color: var(--color-foreground);
  }

  .cs__link {
    display: inline-block;
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: underline;
    text-underline-offset: 3px;
    color: var(--color-foreground);
  }

  .cs__link:hover {
    opacity: 0.65;
  }

  /* --- Dot pagination — mobile only --- */
  .cs__dots {
    display: flex;
    justify-content: center;
    gap: 0.3rem;
    padding: 1.25rem 0 0.5rem;
  }

  @media screen and (min-width: 750px) {
    .cs__dots {
      display: none;
    }
  }

  /* --- Prev/Next controls — desktop only --- */
  .cs__controls {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .cs__controls {
      display: flex;
      justify-content: flex-end;
      gap: 0;
      padding-left: 50%;
    }
  }

  .cs__control-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: none;
    border: none;
    border-bottom: 1.5px solid var(--color-foreground);
    padding: 0.5rem 0;
    margin: 0.75rem 1.25rem 0.5rem 0;
    font-family: var(--font-heading-family);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-foreground);
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .cs__control-btn:hover {
    opacity: 0.55;
  }

  .cs__control-btn svg {
    width: 14px;
    height: 14px;
  }

  .cs__control-btn[data-action="previous"] svg {
    transform: scaleX(-1);
  }

  .cs__dot {
    width: 5px;
    height: 5px;
    border-radius: 0;
    background-color: rgb(0 0 0 / 0.2);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .cs__dot.is-active {
    background-color: rgb(0 0 0 / 0.75);
  }

  /* On dark color schemes, flip dot colors */
  .color-background-2 .cs__dot,
  .color-background-3 .cs__dot,
  .color-inverse .cs__dot {
    background-color: rgb(255 255 255 / 0.35);
  }

  .color-background-2 .cs__dot.is-active,
  .color-background-3 .cs__dot.is-active,
  .color-inverse .cs__dot.is-active {
    background-color: rgb(255 255 255 / 0.9);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Content Slideshow",
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "info": "Small tag overlaid on the image (e.g. SCREEN PRINTING)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Slide heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Describe this slide in a sentence or two."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Content Slideshow",
      "category": "Content",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "label": "SCREEN PRINTING",
            "heading": "Merchandise",
            "text": "We have capabilities to create custom merch for your fans.",
            "link_label": "Learn More"
          }
        },
        {
          "type": "slide",
          "settings": {
            "heading": "Slide Two",
            "link_label": "Learn More"
          }
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "1 / 1", "label": "Square (1:1)" },
        { "value": "4 / 3", "label": "Landscape (4:3)" },
        { "value": "16 / 9", "label": "Wide (16:9)" },
        { "value": "4 / 5", "label": "Portrait (4:5)" },
        { "value": "3 / 4", "label": "Tall (3:4)" }
      ],
      "default": "4 / 3",
      "info": "Controls the image aspect ratio on both mobile and desktop."
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay (seconds)",
      "info": "Set to 0 to disable autoplay",
      "min": 0,
      "max": 10,
      "step": 1,
      "default": 0
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select", 
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}


