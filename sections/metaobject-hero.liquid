{%- liquid
  assign hero_image = nil

  # On a product page: find the first collection with a hero image metafield
  if product != blank
    for col in product.collections
      if col.metafields.custom.hero != blank
        assign hero_image = col.metafields.custom.hero
        break
      endif
    endfor
  endif

  # On a collection page: read directly
  if hero_image == blank and collection != blank and collection.metafields.custom.hero != blank
    assign hero_image = collection.metafields.custom.hero
  endif

  # Manual override from section settings always wins if set
  if section.settings.override_image != blank
    assign hero_image = section.settings.override_image
  endif
-%}

{%- if hero_image == blank -%}
  {%- if request.design_mode -%}
    <div class="metaobject-hero metaobject-hero--placeholder">
      <p class="metaobject-hero__placeholder-text">No hero image found. Assign a hero image to this product's collection metafield (custom.hero), or set a manual override above.</p>
    </div>
  {%- endif -%}
{%- else -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="metaobject-hero color-{{ section.settings.color_scheme }} spacing-style"
  style="
    --moh-height: {{ section.settings.height }}vh;
    --moh-height-mobile: {{ section.settings.height_mobile }}vh;
    --moh-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    {% render 'spacing-style', settings: section.settings %}
  "
>
  <div class="metaobject-hero__media">
    {{
      hero_image
      | image_url: width: 2400
      | image_tag:
        class: 'metaobject-hero__img',
        loading: 'eager',
        fetchpriority: 'high',
        widths: '750, 1100, 1500, 2000, 2400',
        sizes: '100vw',
        alt: section.settings.heading | escape
    }}
    <div class="metaobject-hero__overlay"></div>
  </div>

  {%- if section.settings.heading != blank or section.settings.subtext != blank or section.settings.link_label != blank -%}
    <div class="metaobject-hero__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="metaobject-hero__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <p class="metaobject-hero__subtext">{{ section.settings.subtext | escape }}</p>
      {%- endif -%}

      {%- if section.settings.link_label != blank and section.settings.link_url != blank -%}
        <a href="{{ section.settings.link_url }}" class="metaobject-hero__link button">
          {{ section.settings.link_label | escape }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{%- endif -%}

{% stylesheet %}
  .metaobject-hero {
    position: relative;
    width: 100%;
    height: var(--moh-height-mobile, 70vh);
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  @media screen and (min-width: 750px) {
    .metaobject-hero {
      height: var(--moh-height, 80vh);
    }
  }

  .metaobject-hero__media {
    position: absolute;
    inset: 0;
  }

  .metaobject-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .metaobject-hero__overlay {
    position: absolute;
    inset: 0;
    background-color: #000;
    opacity: var(--moh-overlay, 0.3);
  }

  .metaobject-hero__content {
    position: relative;
    z-index: 2;
    padding: 2rem var(--page-margin, 1rem);
    padding-bottom: 3rem;
    color: #fff;
    max-width: 680px;
  }

  .metaobject-hero__heading {
    margin: 0 0 0.75rem;
    font-family: var(--font-heading-family);
    font-size: clamp(1.75rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    color: #fff;
  }

  .metaobject-hero__subtext {
    margin: 0 0 1.25rem;
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    line-height: 1.5;
    color: rgb(255 255 255 / 0.85);
  }

  .metaobject-hero__link {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    background-color: #fff;
    color: #000;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .metaobject-hero__link:hover {
    background-color: rgb(255 255 255 / 0.85);
  }

  .metaobject-hero--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
    background-color: #f4f4f4;
    border: 2px dashed #ccc;
  }

  .metaobject-hero__placeholder-text {
    color: #888;
    font-size: 0.9rem;
    padding: 1rem;
    text-align: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection Hero",
  "tag": "section",
  "class": "metaobject-hero-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "The hero image is pulled automatically from the product's collection metafield (custom.hero). Use the override below only if you need a specific image on this page."
    },
    {
      "type": "image_picker",
      "id": "override_image",
      "label": "Image override (optional)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Height (desktop)",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 80
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Height (mobile)",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 70
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Collection Hero",
      "category": "Image"
    }
  ]
}
{% endschema %}
