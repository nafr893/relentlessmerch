{%- liquid
  assign hero = nil

  # Auto-mode: find the first collection on this product that has a hero metafield
  if section.settings.use_collection_metafield
    if product != blank
      for col in product.collections
        if col.metafields.custom.hero != blank
          assign hero = col.metafields.custom.hero
          break
        endif
      endfor
    elsif collection != blank and collection.metafields.custom.hero != blank
      assign hero = collection.metafields.custom.hero
    endif
  endif

  # Manual fallback (or manual-only mode)
  if hero == blank and section.settings.hero_entry != blank
    assign hero = section.settings.hero_entry
  endif

  assign has_content = false
  if hero != blank
    assign has_content = true
  endif
-%}

{%- unless has_content -%}
  {%- if request.design_mode -%}
    <div class="metaobject-hero metaobject-hero--placeholder">
      <p class="metaobject-hero__placeholder-text">
        {%- if section.settings.use_collection_metafield -%}
          No hero metafield set on this collection — assign one under Content → Collections → [collection] → Metafields.
        {%- else -%}
          Select a hero entry in section settings.
        {%- endif -%}
      </p>
    </div>
  {%- endif -%}
{%- else -%}

{%- assign hero_image    = hero.image -%}
{%- assign hero_heading  = hero.heading -%}
{%- assign hero_subtext  = hero.subtext -%}
{%- assign hero_link_url = hero.link_url -%}
{%- assign hero_link_label = hero.link_label -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="metaobject-hero color-{{ section.settings.color_scheme }} spacing-style"
  style="
    --moh-height: {{ section.settings.height }}vh;
    --moh-height-mobile: {{ section.settings.height_mobile }}vh;
    --moh-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    {% render 'spacing-style', settings: section.settings %}
  "
>
  {%- if hero_image != blank -%}
    <div class="metaobject-hero__media">
      {{
        hero_image
        | image_url: width: 2400
        | image_tag:
          class: 'metaobject-hero__img',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '750, 1100, 1500, 2000, 2400',
          sizes: '100vw',
          alt: hero_heading | escape
      }}
      <div class="metaobject-hero__overlay"></div>
    </div>
  {%- endif -%}

  <div class="metaobject-hero__content">
    {%- if hero_heading != blank -%}
      <h2 class="metaobject-hero__heading">{{ hero_heading | escape }}</h2>
    {%- endif -%}

    {%- if hero_subtext != blank -%}
      <p class="metaobject-hero__subtext">{{ hero_subtext | escape }}</p>
    {%- endif -%}

    {%- if hero_link_url != blank and hero_link_label != blank -%}
      <a href="{{ hero_link_url }}" class="metaobject-hero__link button">
        {{ hero_link_label | escape }}
      </a>
    {%- endif -%}
  </div>
</div>

{%- endunless -%}

{% stylesheet %}
  .metaobject-hero {
    position: relative;
    width: 100%;
    height: var(--moh-height-mobile, 70vh);
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  @media screen and (min-width: 750px) {
    .metaobject-hero {
      height: var(--moh-height, 80vh);
    }
  }

  /* --- Image ------------------------------------------------ */
  .metaobject-hero__media {
    position: absolute;
    inset: 0;
  }

  .metaobject-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .metaobject-hero__overlay {
    position: absolute;
    inset: 0;
    background-color: #000;
    opacity: var(--moh-overlay, 0.3);
  }

  /* --- Content ---------------------------------------------- */
  .metaobject-hero__content {
    position: relative;
    z-index: 2;
    padding: 2rem var(--page-margin, 1rem);
    padding-bottom: 3rem;
    color: #fff;
    max-width: 680px;
  }

  .metaobject-hero__heading {
    margin: 0 0 0.75rem;
    font-family: var(--font-heading-family);
    font-size: clamp(1.75rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    color: #fff;
  }

  .metaobject-hero__subtext {
    margin: 0 0 1.25rem;
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    line-height: 1.5;
    color: rgb(255 255 255 / 0.85);
  }

  .metaobject-hero__link {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    background-color: #fff;
    color: #000;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .metaobject-hero__link:hover {
    background-color: rgb(255 255 255 / 0.85);
  }

  /* --- Editor placeholder ----------------------------------- */
  .metaobject-hero--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
    background-color: #f4f4f4;
    border: 2px dashed #ccc;
  }

  .metaobject-hero__placeholder-text {
    color: #888;
    font-size: 0.9rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Metaobject Hero",
  "tag": "section",
  "class": "metaobject-hero-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_collection_metafield",
      "label": "Auto-load from collection metafield",
      "default": false,
      "info": "When enabled, reads the hero from the current collection's 'custom.hero' metafield. Falls back to the manual entry below if not set."
    },
    {
      "type": "metaobject",
      "id": "hero_entry",
      "label": "Hero entry (manual)",
      "metaobject_type": "hero"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Height (desktop)",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 80
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Height (mobile)",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 70
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Metaobject Hero",
      "category": "Image"
    }
  ]
}
{% endschema %}
