{%- liquid
  assign hero_image = nil

  # On a product page: find the first collection with a hero image metafield
  if product != blank
    for col in product.collections
      if col.metafields.custom.hero != blank
        assign hero_image = col.metafields.custom.hero
        break
      endif
    endfor
  endif

  # On a collection page: read directly
  if hero_image == blank and collection != blank and collection.metafields.custom.hero != blank
    assign hero_image = collection.metafields.custom.hero
  endif

  # Manual override always wins if set
  if section.settings.override_image != blank
    assign hero_image = section.settings.override_image
  endif
-%}

{%- if hero_image == blank -%}
  {%- if request.design_mode -%}
    <div class="moh-placeholder">
      <p>No hero image found. Assign a hero image to this product's collection metafield (custom.hero), or set a manual override in section settings.</p>
    </div>
  {%- endif -%}
{%- else -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="moh color-{{ section.settings.color_scheme }} spacing-style"
  style="
    --moh-height: {{ section.settings.height }}vh;
    --moh-height-mobile: {{ section.settings.height_mobile }}vh;
    --moh-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    {% render 'spacing-style', settings: section.settings %}
  "
>
  <div class="moh__media">
    {{
      hero_image
      | image_url: width: 2400
      | image_tag:
        class: 'moh__img',
        loading: 'eager',
        fetchpriority: 'high',
        widths: '750, 1100, 1500, 2000, 2400',
        sizes: '100vw',
        alt: ''
    }}
    <div class="moh__overlay"></div>
  </div>

  <div class="moh__content">
    {% content_for 'blocks' %}
  </div>
</div>

{%- endif -%}

{% stylesheet %}
  .moh {
    position: relative;
    width: 100%;
    height: var(--moh-height-mobile, 70vh);
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  @media screen and (min-width: 750px) {
    .moh {
      height: var(--moh-height, 80vh);
    }
  }

  .moh__media {
    position: absolute;
    inset: 0;
  }

  .moh__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .moh__overlay {
    position: absolute;
    inset: 0;
    background-color: #000;
    opacity: var(--moh-overlay, 0.3);
  }

  .moh__content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: 2rem var(--page-margin, 1rem);
    padding-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    color: #fff;
  }

  .moh-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
    background-color: #f4f4f4;
    border: 2px dashed #ccc;
    padding: 1rem;
    text-align: center;
    color: #888;
    font-size: 0.9rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection Hero",
  "tag": "section",
  "class": "moh-section",
  "blocks": [
    { "type": "text", "name": "Text" },
    { "type": "button", "name": "Button" },
    { "type": "popup-link", "name": "Popup link" },
    { "type": "spacer", "name": "Spacer" },
    { "type": "_heading", "name": "Heading" },
    { "type": "_inline-text", "name": "Inline text" }
  ],
  "settings": [
    {
      "type": "paragraph",
      "content": "Image is pulled automatically from the product's collection metafield (custom.hero). Use the override below only if you need a specific image on this page."
    },
    {
      "type": "image_picker",
      "id": "override_image",
      "label": "Image override (optional)"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Height (desktop)",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 80
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Height (mobile)",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 70
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Collection Hero",
      "category": "Image"
    }
  ]
}
{% endschema %}
