<div
  class="artist-search spacing-style"
  style="{% render 'spacing-style', settings: block.settings %}"
  {{ block.shopify_attributes }}
>
  <div class="artist-search__form">
    <span class="svg-wrapper artist-search__icon">
      {{- 'icon-search.svg' | inline_asset_content -}}
    </span>
    <input
      type="search"
      id="artist-search-input-{{ block.id }}"
      placeholder="{{ block.settings.placeholder | default: 'SEARCH...' }}"
      class="artist-search__input"
      autocomplete="off"
      autocorrect="off"
      spellcheck="false"
    >
    <button
      type="button"
      class="artist-search__reset button-unstyled"
      id="artist-search-reset-{{ block.id }}"
      hidden
      aria-label="Clear search"
    >
      <span class="svg-wrapper artist-search__reset-icon">
        {{- 'icon-close.svg' | inline_asset_content -}}
      </span>
    </button>
  </div>
  <p class="artist-search__no-results" id="artist-search-no-results-{{ block.id }}" hidden>
    No artists found.
  </p>
</div>

<script>
(function () {
  const input   = document.getElementById('artist-search-input-{{ block.id }}');
  const reset   = document.getElementById('artist-search-reset-{{ block.id }}');
  const noResults = document.getElementById('artist-search-no-results-{{ block.id }}');
  if (!input) return;

  function getAlphaList() {
    return document.querySelector('.alpha-list__groups');
  }

  function filter(query) {
    const list = getAlphaList();
    if (!list) return;

    const q = query.trim().toLowerCase();
    reset.hidden = q === '';

    const groups  = list.querySelectorAll('.alpha-list__group');
    const navLetters = document.querySelectorAll('.alpha-list__nav-letter--active');
    let totalVisible = 0;

    groups.forEach((group) => {
      const items = group.querySelectorAll('.alpha-list__item');
      let groupVisible = 0;

      items.forEach((item) => {
        const name = item.querySelector('.alpha-list__link')?.textContent?.toLowerCase() ?? '';
        const show = q === '' || name.includes(q);
        item.hidden = !show;
        if (show) groupVisible++;
      });

      group.hidden = groupVisible === 0;
      totalVisible += groupVisible;

      // Dim the matching nav letter if this group is hidden
      const letter = group.querySelector('.alpha-list__letter')?.textContent?.trim();
      if (letter) {
        const navLink = document.querySelector(`.alpha-list__nav-letter[href="#alpha-${letter}"], .alpha-list__nav-letter[href*="-${letter}"]`);
        if (navLink) {
          navLink.style.opacity = groupVisible === 0 ? '0.25' : '';
          navLink.style.pointerEvents = groupVisible === 0 ? 'none' : '';
        }
      }
    });

    noResults.hidden = totalVisible > 0 || q === '';

    // If exactly one visible item and user presses Enter, scroll to it
    if (totalVisible === 1) {
      const visibleLink = list.querySelector('.alpha-list__item:not([hidden]) .alpha-list__link');
      if (visibleLink) {
        visibleLink.closest('.alpha-list__group')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    }
  }

  input.addEventListener('input', () => filter(input.value));

  reset.addEventListener('click', () => {
    input.value = '';
    filter('');
    input.focus();
  });

  // Enter key: scroll to first visible result
  input.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter') return;
    e.preventDefault();
    const list = getAlphaList();
    if (!list) return;
    const first = list.querySelector('.alpha-list__item:not([hidden]) .alpha-list__link');
    if (!first) return;
    const headerHeight = document.querySelector('#header-component, header, .header')?.offsetHeight ?? 0;
    const top = first.getBoundingClientRect().top + window.scrollY - headerHeight - 24;
    window.scrollTo({ top, behavior: 'smooth' });
  });
})();
</script>

{% stylesheet %}
  .artist-search {
    width: 100%;
  }

  .artist-search__form {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    border: 1px solid #d5d5d5;
    color: #888888;
    padding: 0.75rem 1rem;
    background: #FAFAFA;
  }

  .artist-search__icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    width: 1.125rem;
    height: 1.125rem;
    opacity: 0.5;
  }

  .artist-search__icon svg {
    width: 100%;
    height: 100%;
  }

  .artist-search__input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-family: var(--font-heading-family);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-foreground);
    padding: 0;
  }

  .artist-search__input::placeholder {
    color: var(--color-foreground);
    opacity: 0.45;
  }

  /* remove browser default search clear button */
  .artist-search__input::-webkit-search-cancel-button {
    display: none;
  }

  .artist-search__reset[hidden] {
    display: none;
  }

  .artist-search__reset {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    opacity: 0.45;
  }

  .artist-search__reset:hover {
    opacity: 0.8;
  }

  .artist-search__reset-icon svg {
    width: 0.875rem;
    height: 0.875rem;
  }

  .artist-search__no-results {
    margin: 0.75rem 0 0;
    font-size: 0.85rem;
    opacity: 0.55;
    font-family: var(--font-heading-family);
    letter-spacing: 0.05em;
  }

  .artist-search__no-results[hidden] {
    display: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Artist Search",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder text",
      "default": "SEARCH..."
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Artist Search",
      "category": "Search"
    }
  ]
}
{% endschema %}
