{%- doc -%}
 Renders a single tab panel with content routing based on tab ID.


 @param {string} tab - The tab ID ('artists', 'apparel', or 'explore')
 @param {object} linklist - The menu linklist for navigation items
 @param {string} active_tab - The initially active tab ID
 @param {object} block - The block object for settings
 @param {object} section - The section object for settings
 @param {object} block_settings - The block settings object


 @example
 {% render 'tabbed-drawer-panel', tab: 'artists', linklist: linklist, active_tab: 'artists', block_settings: block_settings %}
{%- enddoc -%}


<div
 id="panel-{{ tab }}"
 class="tabbed-drawer__panel"
 role="tabpanel"
 data-tab="{{ tab }}"
 aria-labelledby="tab-{{ tab }}"
 ref="tabPanels[]"
 {% unless tab == active_tab %}hidden{% endunless %}
>
 {% case tab %}

   {% when 'artists' %}
     {%- comment -%} ARTISTS Tab — scrollable menu list {%- endcomment -%}
     <div class="tabbed-drawer__content tabbed-drawer__content--artists">

       {% if block_settings.tabbed_artists_menu != blank %}
         <div class="tabbed-drawer__section">
           <h3 class="tabbed-drawer__section-title">
             {{ block_settings.tabbed_artists_section_heading | default: 'SHOP BY NAME' }}
           </h3>
           <ul class="tabbed-drawer__artist-list" role="list">
             {% for link in linklists[block_settings.tabbed_artists_menu].links %}
               <li class="tabbed-drawer__artist-item">
                 <a href="{{ link.url }}" class="tabbed-drawer__artist-link">{{ link.title }}</a>
               </li>
             {% endfor %}
           </ul>
         </div>
       {% endif %}

       <div class="tabbed-drawer__shop-all-row">
         <a
           href="{{ block_settings.tabbed_artists_shop_all_url | default: '/collections/all' }}"
           class="tabbed-drawer__link-item"
         >
           {{ block_settings.tabbed_artists_shop_all_text | default: 'SHOP ALL' }}
         </a>
       </div>

     </div>


   {% when 'apparel' %}
     {%- comment -%} APPAREL Tab — accordions with selectable menus + Shop All {%- endcomment -%}
     <div class="tabbed-drawer__content tabbed-drawer__content--apparel">

       {% for i in (1..4) %}
         {% assign title_key = 'tabbed_apparel_accordion_' | append: i | append: '_title' %}
         {% assign menu_key  = 'tabbed_apparel_accordion_' | append: i | append: '_menu' %}
         {% assign accordion_title = block_settings[title_key] %}
         {% assign accordion_menu  = block_settings[menu_key] %}

         {% if accordion_title != blank or accordion_menu != blank %}
           <details class="tabbed-drawer__accordion">
             <summary class="tabbed-drawer__accordion-trigger">
               <span>{{ accordion_title | default: 'SECTION' }}</span>
               <span class="tabbed-drawer__accordion-icon">+</span>
             </summary>
             {% if accordion_menu != blank %}
               <div class="tabbed-drawer__accordion-content">
                 <ul role="list">
                   {% for link in linklists[accordion_menu].links %}
                     <li>
                       <a href="{{ link.url }}" class="tabbed-drawer__accordion-link">{{ link.title }}</a>
                     </li>
                   {% endfor %}
                 </ul>
               </div>
             {% endif %}
           </details>
         {% endif %}
       {% endfor %}

       <div class="tabbed-drawer__shop-all-row">
         <a
           href="{{ block_settings.tabbed_apparel_shop_all_url | default: '/collections/all' }}"
           class="tabbed-drawer__link-item"
         >
           {{ block_settings.tabbed_apparel_shop_all_text | default: 'SHOP ALL' }}
         </a>
       </div>

     </div>


   {% when 'explore' %}
     {%- comment -%} EXPLORE Tab — accordions with selectable menus {%- endcomment -%}
     <div class="tabbed-drawer__content tabbed-drawer__content--explore">

       {% for i in (1..4) %}
         {% assign title_key = 'tabbed_explore_accordion_' | append: i | append: '_title' %}
         {% assign menu_key  = 'tabbed_explore_accordion_' | append: i | append: '_menu' %}
         {% assign accordion_title = block_settings[title_key] %}
         {% assign accordion_menu  = block_settings[menu_key] %}

         {% if accordion_title != blank or accordion_menu != blank %}
           <details class="tabbed-drawer__accordion">
             <summary class="tabbed-drawer__accordion-trigger">
               <span>{{ accordion_title | default: 'SECTION' }}</span>
               <span class="tabbed-drawer__accordion-icon">+</span>
             </summary>
             {% if accordion_menu != blank %}
               <div class="tabbed-drawer__accordion-content">
                 <ul role="list">
                   {% for link in linklists[accordion_menu].links %}
                     <li>
                       <a href="{{ link.url }}" class="tabbed-drawer__accordion-link">{{ link.title }}</a>
                     </li>
                   {% endfor %}
                 </ul>
               </div>
             {% endif %}
           </details>
         {% endif %}
       {% endfor %}

     </div>

 {% endcase %}
</div>
